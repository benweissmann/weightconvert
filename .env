# Data files base URL. Empty = served from same origin at /data/.
# Set to your S3 bucket URL for production, e.g.:
#   VITE_DATA_BASE_URL=https://your-bucket.s3.amazonaws.com/weightconvert
VITE_DATA_BASE_URL=

# Model files base URL. Empty = served from same origin at /model/.
# Set to your S3 URL for production, e.g.:
#   VITE_MODEL_BASE_URL=https://your-bucket.s3.amazonaws.com/weightconvert/model
VITE_MODEL_BASE_URL=
